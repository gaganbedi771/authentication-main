79813765880,"results":"20","hashOfConfig":"12"},{"size":240,"mtime":1676431628000,"results":"21","hashOfConfig":"12"},{"filePath":"22","messages":"23","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"10do5c4",{"filePath":"24","messages":"25","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"26","messages":"27","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"28","messages":"29","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"30","messages":"31","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"32","messages":"33","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"34","messages":"35","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"36","messages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"38","messages":"39","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"40"},{"filePath":"41","messages":"42","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\index.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\App.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\pages\\AuthPage.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\pages\\HomePage.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\components\\Layout\\Layout.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\components\\Profile\\UserProfile.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\components\\Layout\\MainNavigation.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\components\\Profile\\ProfileForm.js",[],"C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\components\\Auth\\AuthForm.js",["43"],"import { useState, useRef } from \"react\";\n\nimport classes from \"./AuthForm.module.css\";\n\nconst AuthForm = () => {\n  const [isLogin, setIsLogin] = useState(true);\n  const [email, setEmail] = useState(\"\");\n  const [password, setPassword] = useState(\"\");\n  const [sendingRequest, setSendingRequest] = useState(false);\n\n  const switchAuthModeHandler = () => {\n    setIsLogin((prevState) => !prevState);\n  };\n\n  const loginHandler = async (event) => {\n    event.preventDefault();\n    setSendingRequest((pre) => !pre);\n\n    if (isLogin) {\n      try {\n        const response = await fetch(\n          \"https://identitytoolkit.googleapis.com/v1/accounts:signUp?key=AIzaSyBjN7mZ1axTHHgEQNmj-2DQRlzEmEGyGHw\",\n          {\n            method: \"POST\",\n            body: JSON.stringify({\n              email,\n              password,\n              returnSecureToken: true,\n            }),\n            headers: {\n              \"Content-Type\": \"application/json\",\n            },\n          },\n        );\n\n        if (!response.ok) {\n          throw new Error(\"Authentication failed!, \" + response.data.error.message);\n        }\n\n        const data = await response.json();\n        console.log(data);\n      } catch (error) {\n        alert(error.message);\n      } finally {\n        setSendingRequest((pre) => !pre);\n      }\n    } else {\n      try {\n        const response = await fetch(\n          \"https://identitytoolkit.googleapis.com/v1/accounts:signUp?key=AIzaSyBjN7mZ1axTHHgEQNmj-2DQRlzEmEGyGHw\",\n          {\n            method: \"POST\",\n            body: JSON.stringify({\n              email,\n              password,\n              returnSecureToken: true,\n            }),\n            headers: {\n              \"Content-Type\": \"application/json\",\n            },\n          },\n        );\n\n       if (!response.ok) {\n          throw new Error(\"Authentication failed!, \" + response.data.error.message);\n        }\n\n        const data = await response.json();\n        console.log(data);\n      } catch (error) {\n        console.log(\"else\");\n        alert(error.message);\n      } finally {\n        setSendingRequest((pre) => !pre);\n      }\n    }\n  };\n\n  return (\n    <section className={classes.auth}>\n      <h1>{isLogin ? \"Login\" : \"Sign Up\"}</h1>\n      <form onSubmit={loginHandler}>\n        <div className={classes.control}>\n          <label htmlFor=\"email\">Your Email</label>\n          <input\n            type=\"email\"\n            id=\"email\"\n            value={email}\n            onChange={(e) => {\n              setEmail(e.target.value);\n            }}\n            required\n          />\n        </div>\n        <div className={classes.control}>\n          <label htmlFor=\"password\">Your Password</label>\n          <input\n            type=\"password\"\n            id=\"password\"\n            value={password}\n            onChange={(e) => {\n              setPassword(e.target.value);\n            }}\n            required\n          />\n        </div>\n\n        <div className={classes.actions}>\n          {sendingRequest ? (\n            <p>Sending request...</p>\n          ) : (\n            <button>{isLogin ? \"Login\" : \"Create Account\"}</button>\n          )}\n          <button\n            type=\"button\"\n            className={classes.toggle}\n            onClick={switchAuthModeHandler}\n          >\n            {isLogin ? \"Create new account\" : \"Login with existing account\"}\n          </button>\n        </div>\n      </form>\n    </section>\n  );\n};\n\nexport default AuthForm;\n","C:\\Users\\gagan\\OneDrive\\Desktop\\React\\sharpener react\\Authentication-main\\Authentication-main\\src\\components\\StartingPage\\StartingPageContent.js",[],{"ruleId":"44","severity":1,"message":"45","line":1,"column":20,"nodeType":"46","messageId":"47","endLine":1,"endColumn":26},"no-unused-vars","'useRef' is defined but never used.","Identifier","unusedVar"]